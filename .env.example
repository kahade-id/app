NEXT_PUBLIC_API_URL=https://api.kahade.id

# L-20 FIX: These vars were used in code but missing from .env.example,
# causing silent undefined values for new developers cloning the repo.
NEXT_PUBLIC_APP_URL=https://app.kahade.id
NEXT_PUBLIC_LANDING_URL=https://kahade.id

# Optional: CDN/storage domain for user uploads (avatars, KYC photos)
# Leave empty to disable CDN image optimization
NEXT_PUBLIC_CDN_URL=https://cdn.kahade.id
